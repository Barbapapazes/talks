{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "talks-trigger-redeploy-linked-websites",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-13",
  "workflows": [
    {
      "binding": "TALKS_TRIGGER_REDEPLOY_LINKED_WEBSITES",
      "name": "talks-trigger-redeploy-linked-websites",
      "class_name": "TriggerRedeployLinkedWebsitesWorkflow"
    }
  ],
  "routes": [
    {
      "pattern": "talks-trigger-redeploy-linked-websites.soubiran.dev",
      "zone_name": "soubiran.dev",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "preview_urls": false
}
