{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r run --workspace-concurrency=-1 build && pnpm run generate:redirects && pnpm run generate:meta",
    "export": "pnpm -r run --workspace-concurrency=1 export",
    "thumbnail": "pnpm -r --workspace-concurrency=1 run thumbnail",
    "thumbnail:dark": "pnpm -r --workspace-concurrency=1 run thumbnail:dark",
    "thumbnail:cp": "pnpm -r --workspace-concurrency=-1 run thumbnail:cp",
    "thumbnail:cp:dark": "pnpm -r --workspace-concurrency=-1 run thumbnail:cp:dark",
    "generate:thumbnails": "node .scripts/generate-thumbnails.ts",
    "optimize:thumbnails": "node .scripts/optimize-thumbnails.ts",
    "ready": "node .scripts/ready-deck.ts && pnpm run generate:readme && pnpm run generate:talk-readme",
    "clean": "rm -rf dist && rm -rf slides-export",
    "generate:redirects": "node .scripts/generate-redirects.ts",
    "generate:meta": "node .scripts/generate-meta.ts",
    "generate:readme": "node .scripts/generate-readme.ts",
    "generate:talk-readme": "node .scripts/generate-talk-readme.ts",
    "generate:tree": "node .scripts/generate-tree.ts",
    "dev": "node .scripts/select-deck.ts dev --open",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@formkit/auto-animate": "catalog:",
    "@iconify-json/unjs": "catalog:",
    "@tsparticles/engine": "catalog:",
    "@tsparticles/slim": "catalog:",
    "@unovis/vue": "catalog:",
    "cobe": "catalog:",
    "seedrandom": "catalog:",
    "slidev-addon-inalia": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@iconify-json/devicon": "catalog:",
    "@iconify-json/heroicons": "catalog:",
    "@iconify-json/logos": "catalog:",
    "@iconify-json/lucide": "catalog:",
    "@iconify-json/noto": "catalog:",
    "@iconify-json/ph": "catalog:",
    "@iconify-json/simple-icons": "catalog:",
    "@iconify-json/vscode-icons": "catalog:",
    "@mermaid-js/mermaid-cli": "catalog:",
    "@slidev/cli": "catalog:",
    "@slidev/parser": "catalog:",
    "@slidev/theme-default": "catalog:",
    "@types/node": "catalog:",
    "@types/prompts": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "execa": "catalog:",
    "fdir": "catalog:",
    "gray-matter": "catalog:",
    "markdown-it": "catalog:",
    "ofetch": "catalog:",
    "openai": "catalog:",
    "pathe": "catalog:",
    "playwright-chromium": "catalog:",
    "prettier": "catalog:",
    "prompts": "catalog:",
    "slidev-addon-graph": "catalog:",
    "slidev-theme-personal": "link:./theme",
    "taze": "catalog:",
    "tiktoken": "catalog:",
    "typescript": "catalog:"
  }
}
